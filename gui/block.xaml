<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="root"
        Width="440" Height="170"
        Background="#2D2D30"
        BorderBrush="#555569"
        BorderThickness="1"
        Title="Ай яй яй....."
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <!-- Контейнер для Canvas-позиционирования -->
    <Canvas>

        <!-- Тело сообщения -->
        <TextBlock x:Name="lblMsg1"
                   Canvas.Left="20" Canvas.Top="10"
                   Width="400"
                   Text="Вы не оправдали наше доверие"
                   Foreground="#D0D0D8"/>

        <TextBlock x:Name="lblMsg2"
                   Canvas.Left="20" Canvas.Top="36"
                   Width="400"
                   Text="и были отлучены от нашего сервера."
                   Foreground="#D0D0D8"/>

        <!-- Разделитель -->
        <Separator Canvas.Left="14" Canvas.Top="76"
                   Width="412" Height="1"/>

        <!-- Кнопка OK -->
        <Button x:Name="btnOK"
                Canvas.Left="180" Canvas.Top="88"
                Width="80" Height="34"
                Content="OK"/>

    </Canvas>
</Window>