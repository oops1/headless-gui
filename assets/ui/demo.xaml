<?xml version="1.0" encoding="UTF-8"?>
<!--
    PAM System — главный диалог авторизации
    Разрешение холста: 1920 × 1024
    Координаты дочерних элементов — относительные (стандарт WPF Canvas).
-->
<Panel Name="root" Width="1920" Height="1024" Background="Transparent">

    <!-- ═══════════════════════════════════════════════════════════════
         Главное окно (Win10, полупрозрачный фон)
         ═══════════════════════════════════════════════════════════════ -->
    <Panel Name="mainWin"
           Left="100" Top="80" Right="1820" Bottom="944"
           Style="Win10"/>

    <!-- ── Строка заголовка ──────────────────────────────────────────── -->
    <Panel Name="titleBar"
           Left="100" Top="80" Right="1820" Bottom="126"
           Background="#0078D7">

        <Label Name="winTitle"
               Left="18" Top="13" Right="1600" Bottom="35"
               Text="PAM System — Privileged Access Management"
               Foreground="White"/>

        <!-- Кнопки окна (декоративные) -->
        <Panel Name="btnClose"  Left="1684" Top="0" Right="1720" Bottom="46" Background="#C42B1C">
            <Label Left="9" Top="12" Right="34" Bottom="34" Text="×" Foreground="White"/>
        </Panel>
        <Panel Name="btnMaximize" Left="1648" Top="0" Right="1684" Bottom="46" Background="#373737">
            <Label Left="9" Top="12" Right="34" Bottom="34" Text="□" Foreground="#C8C8C8"/>
        </Panel>
        <Panel Name="btnMinimize" Left="1612" Top="0" Right="1648" Bottom="46" Background="#373737">
            <Label Left="9" Top="12" Right="34" Bottom="34" Text="—" Foreground="#C8C8C8"/>
        </Panel>

    </Panel>

    <!-- ═══════════════════════════════════════════════════════════════
         Левая панель — форма авторизации
         ═══════════════════════════════════════════════════════════════ -->
    <Panel Name="leftPanel"
           Left="110" Top="136" Right="700" Bottom="934"
           Style="Win10">

        <Label Name="formTitle"
               Left="20" Top="14" Right="550" Bottom="38"
               Text="Авторизация"
               Foreground="#B4D2FF"/>

        <!-- Акцентный разделитель под заголовком -->
        <Rectangle Left="20" Top="42" Right="570" Bottom="44"
                   Fill="#0078D7"/>

        <!-- Логин -->
        <Label Left="20" Top="60" Right="440" Bottom="80"
               Text="Имя пользователя:"/>
        <TextBox Name="loginInput"
                 Left="20" Top="84" Right="566" Bottom="118"
                 Placeholder="user@domain.com"
                 Focused="True"/>

        <!-- Пароль -->
        <Label Left="20" Top="136" Right="440" Bottom="156"
               Text="Пароль:"/>
        <PasswordBox Name="passInput"
                     Left="20" Top="160" Right="566" Bottom="194"/>

        <!-- Домен -->
        <Label Left="20" Top="212" Right="440" Bottom="232"
               Text="Домен:"/>
        <TextBox Name="domainInput"
                 Left="20" Top="236" Right="566" Bottom="270"
                 Text="corp.example.com"/>

        <!-- Роль -->
        <Label Left="20" Top="288" Right="440" Bottom="308"
               Text="Роль пользователя:"/>
        <ComboBox Name="roleDD"
                  Left="20" Top="312" Right="566" Bottom="346">
            <Item>Administrator</Item>
            <Item>Operator</Item>
            <Item>Auditor</Item>
            <Item>Read-only</Item>
        </ComboBox>

        <!-- CheckBox: запомнить меня -->
        <CheckBox Name="cbRemember"
                  Left="20" Top="364" Right="290" Bottom="388"
                  Content="Запомнить меня" IsChecked="True"/>

        <!-- RadioButton: тип входа -->
        <Label Left="20" Top="400" Right="290" Bottom="420"
               Text="Тип аутентификации:" Foreground="#B4B4B4"/>
        <RadioButton Name="rbLDAP"
                     Left="20" Top="424" Right="240" Bottom="448"
                     Content="LDAP / AD" GroupName="authType" IsChecked="True"/>
        <RadioButton Name="rbOTP"
                     Left="20" Top="452" Right="240" Bottom="476"
                     Content="Одноразовый пароль" GroupName="authType"/>
        <RadioButton Name="rbCert"
                     Left="20" Top="480" Right="240" Bottom="504"
                     Content="Сертификат" GroupName="authType"/>

        <!-- Кнопки действия -->
        <Button Name="btnLogin"
                Left="20" Top="524" Right="200" Bottom="564"
                Content="  Войти  "
                Style="Accent"/>
        <Button Name="btnCancel"
                Left="218" Top="524" Right="380" Bottom="564"
                Content="Отмена"/>

        <!-- Разделитель -->
        <Separator Left="20" Top="582" Right="570" Bottom="584"/>

        <!-- Вспомогательный текст -->
        <Label Name="hintLbl"
               Left="20" Top="594" Right="566" Bottom="614"
               Text="Используйте корпоративный аккаунт Active Directory"
               Foreground="#828282"/>

    </Panel>

    <!-- ═══════════════════════════════════════════════════════════════
         Правая панель — статистика движка
         ═══════════════════════════════════════════════════════════════ -->
    <Panel Name="rightPanel"
           Left="720" Top="136" Right="1810" Bottom="934"
           Style="Win10">

        <Label Name="statsTitle"
               Left="20" Top="14" Right="480" Bottom="38"
               Text="Статистика движка"
               Foreground="#B4D2FF"/>

        <Rectangle Left="20" Top="42" Right="1080" Bottom="44"
                   Fill="#0078D7"/>

        <!-- Метрики -->
        <Label Name="frameLabel"
               Left="20" Top="60" Right="480" Bottom="82"
               Text="Кадр: —"
               Background="#2B2B2BDC"/>

        <Label Name="tilesLabel"
               Left="20" Top="90" Right="480" Bottom="112"
               Text="Тайлов: —"
               Background="#2B2B2BDC"/>

        <Label Name="bytesLabel"
               Left="20" Top="120" Right="480" Bottom="142"
               Text="Байт/кадр: —"
               Background="#2B2B2BDC"/>

        <Separator Left="20" Top="162" Right="1080" Bottom="164"/>

        <!-- Прогресс-бар -->
        <Label Left="20" Top="174" Right="280" Bottom="194"
               Text="Загрузка системы:"/>
        <ProgressBar Name="pb"
                     Left="20" Top="202" Right="1080" Bottom="232"/>
        <Label Name="pbPct"
               Left="20" Top="246" Right="180" Bottom="266"
               Text="0%"
               Background="#2B2B2BDC"/>

        <Separator Left="20" Top="284" Right="1080" Bottom="286"/>

        <!-- Статус -->
        <Label Name="statusLabel"
               Left="20" Top="298" Right="1080" Bottom="320"
               Text="Status: ожидание…"
               Background="#2B2B2BDC"/>

        <!-- Панель инструментов -->
        <Button Name="btnReset"
                Left="20" Top="344" Right="180" Bottom="382"
                Content="Сброс"/>
        <Button Name="btnExport"
                Left="198" Top="344" Right="370" Bottom="382"
                Content="Экспорт"
                Style="Accent"/>
        <Button Name="btnThemeToggle"
                Left="388" Top="344" Right="620" Bottom="382"
                Content="Светлая тема"/>

        <!-- ═══ Новые виджеты ═══ -->
        <Separator Left="20" Top="400" Right="1080" Bottom="402"/>

        <Label Left="20" Top="412" Right="480" Bottom="432"
               Text="Демо новых виджетов"
               Foreground="#B4D2FF"/>

        <!-- ToggleSwitch -->
        <ToggleSwitch Name="tsAutoRefresh"
                      Left="20" Top="442" Right="380" Bottom="468"
                      Content="Авто-обновление" IsOn="True"/>

        <ToggleSwitch Name="tsNotify"
                      Left="20" Top="476" Right="380" Bottom="502"
                      Content="Уведомления"/>

        <!-- Slider -->
        <Label Left="20" Top="514" Right="280" Bottom="534"
               Text="Скорость обновления:"/>
        <Slider Name="sliderSpeed"
                Left="20" Top="538" Right="380" Bottom="568"
                Minimum="1" Maximum="60" Value="20"/>
        <Label Name="lblSpeedVal"
               Left="390" Top="544" Right="530" Bottom="564"
               Text="20 FPS"
               Background="#2B2B2BDC"/>

        <!-- ListView -->
        <Label Left="20" Top="582" Right="380" Bottom="602"
               Text="Журнал событий:"/>
        <ListView Name="eventLog"
                  Left="20" Top="606" Right="480" Bottom="784"
                  ItemHeight="24"/>

        <!-- Счётчики справа от ListView -->
        <Label Left="500" Top="412" Right="1080" Bottom="432"
               Text="Настройки сессии"
               Foreground="#B4D2FF"/>

        <CheckBox Name="cbVerbose"
                  Left="500" Top="442" Right="780" Bottom="466"
                  Content="Verbose логирование"/>
        <CheckBox Name="cbCompress"
                  Left="500" Top="474" Right="780" Bottom="498"
                  Content="Сжатие тайлов" IsChecked="True"/>
        <CheckBox Name="cbEncrypt"
                  Left="500" Top="506" Right="780" Bottom="530"
                  Content="Шифрование"/>

        <!-- RadioButton: формат экспорта -->
        <Label Left="500" Top="546" Right="780" Bottom="566"
               Text="Формат экспорта:" Foreground="#B4B4B4"/>
        <RadioButton Name="rbPNG"
                     Left="500" Top="570" Right="780" Bottom="594"
                     Content="PNG" GroupName="exportFmt" IsChecked="True"/>
        <RadioButton Name="rbJPEG"
                     Left="500" Top="598" Right="780" Bottom="622"
                     Content="JPEG" GroupName="exportFmt"/>
        <RadioButton Name="rbRAW"
                     Left="500" Top="626" Right="780" Bottom="650"
                     Content="RAW RGBA" GroupName="exportFmt"/>

        <!-- Второй Slider: качество -->
        <Label Left="500" Top="666" Right="780" Bottom="686"
               Text="Качество:"/>
        <Slider Name="sliderQuality"
                Left="500" Top="690" Right="880" Bottom="720"
                Minimum="1" Maximum="100" Value="80"/>
        <Label Name="lblQualityVal"
               Left="890" Top="696" Right="1070" Bottom="716"
               Text="80%"
               Background="#2B2B2BDC"/>

    </Panel>

</Panel>
