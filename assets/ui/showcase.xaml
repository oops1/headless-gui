<?xml version="1.0" encoding="UTF-8"?>
<!--
    GuiEngine — Widget Showcase
    Демонстрация ВСЕХ доступных виджетов движка.
    WPF-совместимый XAML.
-->
<Canvas Name="root" Width="1280" Height="900" Background="#0D0D1A">

