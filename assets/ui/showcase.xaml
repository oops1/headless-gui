               Text="GuiEngine — Widget Showcase" Foreground="White"/>
        <Label Name="headerClock" Left="1080" Top="14" Width="180" Height="24"
               Text="00:00:00" Foreground="#B0D4FF"/>
    </Panel>

    <!-- ═══════════════════════════════════════════════════════════════════════
         MENU BAR — горизонтальное меню
         ═══════════════════════════════════════════════════════════════════════ -->
    <Menu Name="mainMenu" Left="0" Top="52" Width="1280" Height="28">
        <MenuItem Header="Файл">
            <MenuItem Text="Новый"/>
            <MenuItem Text="Открыть"/>
            <MenuItem Text="Сохранить"/>
            <MenuItem Separator="True"/>
            <MenuItem Text="Экспорт..."/>
            <MenuItem Separator="True"/>
            <MenuItem Text="Выход"/>
        </MenuItem>
        <MenuItem Header="Правка">
            <MenuItem Text="Отменить"/>
            <MenuItem Text="Повторить"/>
            <MenuItem Separator="True"/>
            <MenuItem Text="Вырезать"/>
            <MenuItem Text="Копировать"/>
            <MenuItem Text="Вставить"/>
            <MenuItem Separator="True"/>
            <MenuItem Text="Выделить всё"/>
        </MenuItem>
        <MenuItem Header="Вид">
            <MenuItem Text="Панель инструментов"/>
            <MenuItem Text="Строка состояния"/>
            <MenuItem Separator="True"/>
            <MenuItem Text="Масштаб 100%"/>
            <MenuItem Text="Масштаб 150%"/>
        </MenuItem>
        <MenuItem Header="Подключение">
            <MenuItem Text="Новое подключение"/>
            <MenuItem Text="Быстрое подключение"/>
            <MenuItem Separator="True"/>
            <MenuItem Text="Отключить"/>
        </MenuItem>
        <MenuItem Header="Справка">
            <MenuItem Text="Документация"/>
            <MenuItem Text="Горячие клавиши"/>
            <MenuItem Separator="True"/>
            <MenuItem Text="О программе"/>
        </MenuItem>
