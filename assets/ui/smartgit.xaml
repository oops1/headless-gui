<Window x:Class="SmartGitLike.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartGit-like UI" Height="700" Width="1100"
        Background="#1E1E1E">

    <DockPanel>
        <!-- Menu -->
        <Menu Name="mainMenu" DockPanel.Dock="Top" Background="#2D2D30" Foreground="White">
            <MenuItem Header="File">
                <MenuItem Header="Exit"/>
            </MenuItem>
            <MenuItem Header="Settings">
                <MenuItem Header="Theme">
                    <MenuItem Header="Dark"/>
                    <MenuItem Header="Light"/>
                </MenuItem>
                <MenuItem Header="Title Style">
                    <MenuItem Header="Windows Style"/>
                    <MenuItem Header="Mac Style"/>
                </MenuItem>
            </MenuItem>
        </Menu>

        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <DockPanel Grid.Row="0" Background="#2D2D30">
            <StackPanel Orientation="Horizontal" Margin="5">
                <Button Content="Commit" Icon="img/commit.png" Margin="2"/>
                <Button Content="Pull" Icon="img/pull.png" Margin="2"/>
                <Button Content="Push" Icon="img/push.png" Margin="2"/>
                <Button Content="Branch" Icon="img/branch.png" Margin="2"/>
                <Button Content="Log" Icon="img/log.png" Margin="2"/>
            </StackPanel>
        </DockPanel>

        <!-- Main area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Repository Tree -->
            <Border Background="#252526" Grid.Column="0">
                <TreeView Foreground="White" Background="Transparent">
                    <TreeViewItem Header="Repository">
                        <TreeViewItem Header="src"/>
                        <TreeViewItem Header="docs"/>
                        <TreeViewItem Header=".git"/>
                    </TreeViewItem>
                </TreeView>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" Background="#3F3F46"/>

            <!-- Right side -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="3*"/>
                </Grid.RowDefinitions>

                <!-- Changes list -->
                <DataGrid Grid.Row="0" Background="#1E1E1E" Foreground="White"
                          HeadersVisibility="Column" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="*"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Splitter -->
                <GridSplitter Grid.Row="1" Height="5" Background="#3F3F46"/>

                <!-- Diff view -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left diff -->
                    <TextBox Grid.Column="0" Background="#1E1E1E" Foreground="LightGray"
                             Text="Old version" AcceptsReturn="True"/>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="5" Background="#3F3F46"/>

                    <!-- Right diff -->
                    <TextBox Grid.Column="2" Background="#1E1E1E" Foreground="White"
                             Text="New version" AcceptsReturn="True"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <StatusBar Grid.Row="2" Background="#2D2D30" Foreground="White">
            <TextBlock Text="Ready"/>
        </StatusBar>
    </Grid>
    </DockPanel>
</Window>
